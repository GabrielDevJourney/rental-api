            {
              "id": "evt-rent-completed-test",
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Is completed', () => pm.expect(pm.response.json().data.rentalStatus).to.eql('COMPLETED'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/rentals/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rentals", "1"]
