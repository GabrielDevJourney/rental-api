        {
          "name": "POST Create Rental - Valid (Lamborghini / Admin)",
          "event": [
            {
              "id": "evt-rent-create-prereq",
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const today = new Date();",
                  "const start = new Date(today); start.setDate(today.getDate() + 2);",
                  "const end = new Date(today); end.setDate(today.getDate() + 6);",
                  "const fmt = d => d.toISOString().slice(0, 10);",
                  "pm.collectionVariables.set('rentalStartDate', fmt(start));",
                  "pm.collectionVariables.set('rentalEndDate', fmt(end));"
                ]
              }
            },
            {
              "id": "evt-rent-create-test",
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accountId\": 1,\n  \"vehicleId\": 2,\n  \"dateStart\": \"{{rentalStartDate}}\",\n  \"dateEnd\": \"{{rentalEndDate}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/rentals",
              "host": ["{{baseUrl}}"],
              "path": ["api", "rentals"]
            }
          }
        },
