{
  "info": {
    "_postman_id": "rentacar-api-collection-v1",
    "name": "Rentacar API",
    "description": "Run folders in order: Auth → Accounts → Vehicles → Rentals.\nAuth folder must run first to populate adminToken, managerToken, and userToken variables.\n\nSeeded accounts: admin@rentacar.com (ADMIN), manager@rentacar.com (MANAGER), user@rentacar.com (USER), inactive@rentacar.com (inactive USER)\nSeeded vehicles: IDs 1–5 (Ferrari AVAILABLE, Lamborghini AVAILABLE, Porsche MAINTENANCE, Bentley RENTED, Aston Martin AVAILABLE)\nSeeded rentals: ID 1 (COMPLETED), ID 2 (ACTIVE)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string", "enabled": true },
    { "key": "adminToken", "value": "", "type": "string", "enabled": true },
    { "key": "managerToken", "value": "", "type": "string", "enabled": true },
    { "key": "userToken", "value": "", "type": "string", "enabled": true },
    { "key": "rentalStartDate", "value": "", "type": "string", "enabled": true },
    { "key": "rentalEndDate", "value": "", "type": "string", "enabled": true }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Public endpoints — no token required. Run all login requests first to populate tokens.",
      "item": [
        {
          "name": "Login - Admin",
          "event": [
            {
              "id": "evt-auth-admin-test",
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Token present', () => pm.expect(pm.response.json().data.token).to.not.be.empty);",
                  "if (pm.response.code === 200) {",
                  "    pm.collectionVariables.set('adminToken', pm.response.json().data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@rentacar.com\",\n  \"password\": \"Admin@1234!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Login - Manager",
          "event": [
            {
              "id": "evt-auth-manager-test",
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "if (pm.response.code === 200) {",
                  "    pm.collectionVariables.set('managerToken', pm.response.json().data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
